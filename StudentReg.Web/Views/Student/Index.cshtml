@model IEnumerable<StudentReg.Domain.Entities.Student>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="fas fa-users me-2"></i>Registered Students</h2>
        <a asp-action="Register" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus"></i> New Registration
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Full Name</th>
                    <th>Email</th>
                    <th>Newsletter</th>
                    <th>Preference</th>
                    <th class="text-center">Actions</th> @* New Column *@
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) 
                {
                    <tr>
                        <td class="ps-4">@item.FirstName @item.MiddleName @item.LastName</td>
                        <td>@item.Email</td>
                        <td>
                            @if(item.EnrollNewsletter) {
                                <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Enrolled</span>
                            } else {
                                <span class="badge bg-secondary"><i class="fas fa-times-circle me-1"></i>No</span>
                            }
                        </td>
                        <td>
                            @if(item.EnrollNewsletter) {
                                <span class="text-dark"><i class="fas fa-clock me-1 text-primary"></i>@item.Preference</span>
                            } else {
                                <span class="text-muted small">N/A</span>
                            }
                        </td>
                        <td class="text-center">
                            @* Delete Form *@
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this student?');">
                                <button type="submit" class="btn btn-link text-danger p-0">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center p-5">
                <p class="text-muted">No students registered yet.</p>
            </div>
        }
    </div>
</div>