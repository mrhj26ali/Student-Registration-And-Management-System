<div>
    <div class="toolbar">
        <button id="btnToggle">Stop</button>
        <button id="btnReverse">Reverse</button>
        <span class="label">Speed:</span>
        <input type="range" id="speedSlider" min="0.1" max="5" step="0.1" value="2">
        <span class="label">Petals:</span>
        <input type="number" id="petalInput" value="8" min="3" max="24">
    </div>

    <div class="viewport">
        <div id="flower-center" class="flower">
            <div class="core"></div>
            <div id="rotation-wrapper">
                <div id="petal-layer"></div>
            </div>
        </div>
    </div>
</div>